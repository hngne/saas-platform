generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DB_PLATFORM_URL")
}

model Admin {
  id         String   @id @default(uuid()) @db.VarChar(36)
  email      String   @unique @db.VarChar(100)
  password   String   @db.VarChar(255)
  name       String?  @db.VarChar(100)
  role       String   @default("ADMIN") @db.VarChar(20)
  status     String   @default("ACTIVE") @db.VarChar(20)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([email])
  @@map("admins")
}

model Tenant {
  id            String         @id @default(uuid()) @db.VarChar(36)
  slug          String         @unique @db.VarChar(100)
  business_type String         @db.VarChar(20)
  db_name       String         @unique @db.VarChar(100)
  status        String         @default("ACTIVE") @db.VarChar(20)
  created_at    DateTime       @default(now())
  updated_at    DateTime       @updatedAt
  profile       TenantProfile?

  @@index([slug])
  @@index([status])
  @@map("tenants")
}

model TenantProfile {
  id                String   @id @default(uuid()) @db.VarChar(36)
  tenant_id         String   @unique @db.VarChar(36)
  owner_name        String?  @db.VarChar(100)
  phone             String?  @db.VarChar(20)
  email             String?  @db.VarChar(100)
  address           String?  @db.Text
  tax_code          String?  @db.VarChar(50)
  store_name        String?  @db.VarChar(100)
  store_description String?  @db.Text
  logo_url          String?  @db.VarChar(255)
  favicon_url       String?  @db.VarChar(255)
  primary_color     String?  @db.VarChar(20)
  secondary_color   String?  @db.VarChar(20)
  banner_url        String?  @db.VarChar(255)
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt
  tenant            Tenant   @relation(fields: [tenant_id], references: [id])

  @@index([tenant_id])
  @@map("tenant_profiles")
}

model RefreshToken {
  id         String   @id @default(uuid()) @db.VarChar(36)
  user_id    String   @db.VarChar(36)
  user_type  String   @db.VarChar(20)
  token      String   @unique @db.VarChar(500)
  expires_at DateTime
  created_at DateTime @default(now())

  @@index([user_id, user_type])
  @@map("refresh_tokens")
}
